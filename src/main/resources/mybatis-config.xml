<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <typeAliases>
        <typeAlias alias="Beatmap" type="com.github.hoshinotented.osuutils.database.BeatmapInDb"/>
        <typeAlias alias="BeatmapSet" type="com.github.hoshinotented.osuutils.database.BeatmapSetInDb"/>
    </typeAliases>
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="org.sqlite.JDBC"/>
                <property name="url" value="jdbc:sqlite::memory:"/>
            </dataSource>
        </environment>
    </environments>
    <mappers>
        <mapper resource="mappers/BeatmapMapper.xml"/>
    </mappers>
</configuration>